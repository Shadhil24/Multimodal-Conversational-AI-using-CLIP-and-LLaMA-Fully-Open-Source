# Copy this file to .env and fill in your values

SECRET_KEY=your-secret-key-here

# Vision: blip (open caption, recommended), clip (fixed labels only), or both
VISION_BACKEND=blip

# Optional: Hugging Face model id for captioning
# BLIP_MODEL_NAME=Salesforce/blip-image-captioning-base
# Richer captions: longer decode + dual BLIP pass (defaults on)
# BLIP_MAX_CAPTION_LEN=140
# BLIP_USE_DUAL_CAPTION=true
# BLIP_CONDITIONAL_PREFIX=a detailed photograph showing

# Ollama output length (tokens)
# OLLAMA_DESCRIPTION_MAX_TOKENS=420
# OLLAMA_CHAT_MAX_TOKENS=600
# Friendlier chat replies (higher = more varied; default 0.72)
# OLLAMA_CHAT_TEMPERATURE=0.72

# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model to use
OLLAMA_MODEL=llama3.2:1b

# Chat: max prior turns sent to Ollama (user + assistant messages)
# CHAT_MAX_HISTORY_MESSAGES=40
